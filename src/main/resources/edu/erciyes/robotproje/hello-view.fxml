<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.erciyes.robotproje.HelloController">

  <top>
    <HBox alignment="CENTER"
          prefHeight="80"
          style="-fx-background-color:#0B1F3A;">
      <Label text="Robot Süpürge Simülasyonu"
             style="-fx-text-fill:white;
                          -fx-font-size:32;
                          -fx-font-weight:bold;"/>
    </HBox>
  </top>


    <left>
      <VBox prefWidth="220"
            spacing="6"
            style="-fx-background-color:#102B4E;
                 -fx-padding:10;">

      <Label text="🔧 Araçlar"
             style="-fx-text-fill:white;
                          -fx-font-size:15;
                          -fx-font-weight:bold;"/>

      <Button text="Kir Ekle"
              prefHeight="28"
              maxWidth="9999"
              style="-fx-background-color:#2F80ED;
                           -fx-text-fill:white;
                           -fx-font-size:14;"/>

      <Label text="Kir Türü"
             style="-fx-text-fill:white;
                          -fx-font-size:14;"/>

      <RadioButton text="Toz"
                   style="-fx-text-fill:white;"/>

      <RadioButton text="Sıvı"
                   style="-fx-text-fill:white;"/>

      <RadioButton text="Leke"
                   style="-fx-text-fill:white;"/>

      <Button text="Mobilya Ekle"
              prefHeight="28"
              maxWidth="9999"
              style="-fx-background-color:#27AE60;
                           -fx-text-fill:white;
                           -fx-font-size:14;"/>

      <Separator/>

      <Label text="⚡ Robot Hızı"
             style="-fx-text-fill:white;
                          -fx-font-size:15;
                          -fx-font-weight:bold;"/>

      <Slider fx:id="speedSlider"
              min="0.5"
              max="2.0"
              value="1.0"/>

      <Label fx:id="speedLabel"
             text="1.0x"
             style="-fx-text-fill:white;"/>

      <Separator/>

      <Label text="⚙ Temizlik Algoritması"
             style="-fx-text-fill:white;
                          -fx-font-size:15;
                          -fx-font-weight:bold;"/>

      <RadioButton text="Rastgele"
                   style="-fx-text-fill:white;"/>

      <RadioButton text="Spiral"
                   style="-fx-text-fill:white;"/>

      <RadioButton text="Duvar Takip"
                   style="-fx-text-fill:white;"/>

      <Separator/>

      <Label text="🤖 Robot Durumu"
             style="-fx-text-fill:white;
              -fx-font-size:15;
              -fx-font-weight:bold;"/>

      <Label text="Konum: (0,0)"
             fx:id="positionLabel"
             style="-fx-text-fill:white;"/>

      <Label text="Yön: Sağ"
             fx:id="directionLabel"
             style="-fx-text-fill:white;"/>

      <Label text="Batarya"
             style="-fx-text-fill:white;"/>

      <ProgressBar fx:id="batteryBar"
                   progress="1.0"/>

      <Separator/>

      <Label text="🎮 Kontroller"
             style="-fx-text-fill:white;
              -fx-font-size:15;
              -fx-font-weight:bold;"/>

      <Button text="▶ Başlat"
              prefHeight="28"
              maxWidth="9999"
              style="-fx-background-color:#2F80ED;
               -fx-text-fill:white;
               -fx-font-size:14;"/>

      <Button text="⏸ Duraklat"
              prefHeight="28"
              maxWidth="9999"
              style="-fx-background-color:#6C757D;
               -fx-text-fill:white;
               -fx-font-size:14;"/>

      <Button text="🔄 Sıfırla"
              prefHeight="28"
              maxWidth="9999"
              style="-fx-background-color:#DC3545;
               -fx-text-fill:white;
               -fx-font-size:14;"/>

      <Button text="🏠 İstasyona Dön"
              prefHeight="28"
              maxWidth="9999"
              style="-fx-background-color:#17A2B8;
               -fx-text-fill:white;
               -fx-font-size:14;"/>


      </VBox>
    </left>
  <center>
    <AnchorPane fx:id="simulationPane"
                style="-fx-background-color:#EAD7B8;">
    </AnchorPane>
  </center>

  <bottom>
    <HBox prefHeight="90"
          spacing="40"
          alignment="CENTER"
          style="-fx-background-color:#0B1F3A;
                 -fx-padding:10;">

      <VBox alignment="CENTER">
        <Label text="🔵 Toplam Alan"
               style="-fx-text-fill:white;
                          -fx-font-size:14;"/>
        <Label text="400 m²"
               fx:id="totalAreaLabel"
               style="-fx-text-fill:white;
                          -fx-font-size:18;
                          -fx-font-weight:bold;"/>
      </VBox>

      <Separator orientation="VERTICAL"/>

      <VBox alignment="CENTER">
        <Label text="🟢 Temizlenen Alan"
               style="-fx-text-fill:white;
                          -fx-font-size:14;"/>
        <Label text="0 m² (0%)"
               fx:id="cleanedAreaLabel"
               style="-fx-text-fill:white;
                          -fx-font-size:18;
                          -fx-font-weight:bold;"/>
      </VBox>

      <Separator orientation="VERTICAL"/>

      <VBox alignment="CENTER">
        <Label text="⚪ Kalan Alan"
               style="-fx-text-fill:white;
                          -fx-font-size:14;"/>
        <Label text="400 m² (100%)"
               fx:id="remainingAreaLabel"
               style="-fx-text-fill:white;
                          -fx-font-size:18;
                          -fx-font-weight:bold;"/>
      </VBox>

      <Separator orientation="VERTICAL"/>

      <VBox alignment="CENTER">
        <Label text="🕒 Geçen Süre"
               style="-fx-text-fill:white;
                          -fx-font-size:14;"/>
        <Label text="00:00"
               fx:id="timeLabel"
               style="-fx-text-fill:white;
                          -fx-font-size:18;
                          -fx-font-weight:bold;"/>
      </VBox>

      <Separator orientation="VERTICAL"/>

      <VBox alignment="CENTER">
        <Label text="🧹 Toplanan Toz"
               style="-fx-text-fill:white;
                          -fx-font-size:14;"/>
        <Label text="0%"
               fx:id="dustLabel"
               style="-fx-text-fill:white;
                          -fx-font-size:18;
                          -fx-font-weight:bold;"/>
      </VBox>

    </HBox>
  </bottom>

</BorderPane>