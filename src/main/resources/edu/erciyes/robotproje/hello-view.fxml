<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.erciyes.robotproje.HelloController">

  <top>
    <HBox alignment="CENTER" prefHeight="80" style="-fx-background-color:#0B1F3A;">
      <Label style="-fx-text-fill:white;                           -fx-font-size:32;                           -fx-font-weight:bold;" text="Robot Süpürge Simülasyonu" />
    </HBox>
  </top>


    <left>
      <VBox prefWidth="220" spacing="6" style="-fx-background-color:#102B4E;                  -fx-padding:10;">

      <Label style="-fx-text-fill:white;                           -fx-font-size:15;                           -fx-font-weight:bold;" text="🔧 Araçlar" />

      <Button fx:id="addDirtButton" maxWidth="9999" prefHeight="28" style="-fx-background-color:#2F80ED;                            -fx-text-fill:white;                            -fx-font-size:14;" text="Kir Ekle" />

      <Label style="-fx-text-fill:white;                           -fx-font-size:14;" text="Kir Türü" />

      <RadioButton fx:id="dustRadioButton" style="-fx-text-fill:white;" text="Toz" />

      <RadioButton fx:id="liquidRadioButton" style="-fx-text-fill:white;" text="Sıvı" />

      <RadioButton fx:id="stainRadioButton" style="-fx-text-fill:white;" text="Leke" />

      <Button fx:id="addObstacleButton" maxWidth="9999" prefHeight="28" style="-fx-background-color:#27AE60;                            -fx-text-fill:white;                            -fx-font-size:14;" text="Mobilya Ekle" />

      <Separator />

      <Label style="-fx-text-fill:white;                           -fx-font-size:15;                           -fx-font-weight:bold;" text="⚡ Robot Hızı" />

      <Slider fx:id="speedSlider" max="2.0" min="0.5" value="1.0" />

      <Label fx:id="speedLabel" style="-fx-text-fill:white;" text="1.0x" />

      <Separator />

      <Label style="-fx-text-fill:white;                           -fx-font-size:15;                           -fx-font-weight:bold;" text="⚙ Temizlik Algoritması" />

      <RadioButton fx:id="randomRadioButton" style="-fx-text-fill:white;" text="Rastgele" />

      <RadioButton fx:id="spiralRadioButton" style="-fx-text-fill:white;" text="Spiral" />

      <RadioButton fx:id="wallFollowRadioButton" style="-fx-text-fill:white;" text="Duvar Takip" />

      <Separator />

      <Label style="-fx-text-fill:white;               -fx-font-size:15;               -fx-font-weight:bold;" text="🤖 Robot Durumu" />

      <Label fx:id="positionLabel" style="-fx-text-fill:white;" text="Konum: (0,0)" />

      <Label fx:id="directionLabel" style="-fx-text-fill:white;" text="Yön: Sağ" />

      <Label style="-fx-text-fill:white;" text="Batarya" />
         <Label fx:id="batteryPercentageLabel" prefHeight="17.0" prefWidth="88.0" text="\%100.0" textFill="WHITE" />

      <ProgressBar fx:id="batteryBar" prefHeight="18.0" prefWidth="172.0" progress="1.0" />

      <Separator />

      <Label style="-fx-text-fill:white;               -fx-font-size:15;               -fx-font-weight:bold;" text="🎮 Kontroller" />

      <Button fx:id="startButton" maxWidth="9999" prefHeight="28" style="-fx-background-color:#2F80ED;                -fx-text-fill:white;                -fx-font-size:14;" text="▶ Başlat" />

      <Button maxWidth="9999" onAction="#onDuraklatClick" prefHeight="28" style="-fx-background-color:#6C757D;                -fx-text-fill:white;                -fx-font-size:14;" text="⏸ Duraklat" />

      <Button maxWidth="9999" onAction="#onSifirlaClick" prefHeight="28" style="-fx-background-color:#DC3545;                -fx-text-fill:white;                -fx-font-size:14;" text="🔄 Sıfırla" />

      <Button maxWidth="9999" prefHeight="28" style="-fx-background-color:#17A2B8;                -fx-text-fill:white;                -fx-font-size:14;" text="🏠 İstasyona Dön" />


      </VBox>
    </left>
  <center>
    <AnchorPane fx:id="simulationPane" style="-fx-background-color:#EAD7B8;">
    </AnchorPane>
  </center>

  <bottom>
    <HBox alignment="CENTER" prefHeight="90" spacing="40" style="-fx-background-color:#0B1F3A;                  -fx-padding:10;">

      <VBox alignment="CENTER">
        <Label style="-fx-text-fill:white;                           -fx-font-size:14;" text="🔵 Toplam Alan" />
        <Label fx:id="totalAreaLabel" style="-fx-text-fill:white;                           -fx-font-size:18;                           -fx-font-weight:bold;" text="400 m²" />
      </VBox>

      <Separator orientation="VERTICAL" />

      <VBox alignment="CENTER">
        <Label style="-fx-text-fill:white;                           -fx-font-size:14;" text="🟢 Temizlenen Alan" />
        <Label fx:id="cleanedAreaLabel" style="-fx-text-fill:white;                           -fx-font-size:18;                           -fx-font-weight:bold;" text="0 m² (0%)" />
      </VBox>

      <Separator orientation="VERTICAL" />

      <VBox alignment="CENTER">
        <Label style="-fx-text-fill:white;                           -fx-font-size:14;" text="⚪ Kalan Alan" />
        <Label fx:id="remainingAreaLabel" style="-fx-text-fill:white;                           -fx-font-size:18;                           -fx-font-weight:bold;" text="400 m² (100%)" />
      </VBox>

      <Separator orientation="VERTICAL" />

      <VBox alignment="CENTER">
        <Label style="-fx-text-fill:white;                           -fx-font-size:14;" text="🕒 Geçen Süre" />
        <Label fx:id="timeLabel" style="-fx-text-fill:white;                           -fx-font-size:18;                           -fx-font-weight:bold;" text="00:00" />
      </VBox>

      <Separator orientation="VERTICAL" />

      <VBox alignment="CENTER">
        <Label style="-fx-text-fill:white;                           -fx-font-size:14;" text="🧹 Toplanan Toz" />
        <Label fx:id="dustLabel" style="-fx-text-fill:white;                           -fx-font-size:18;                           -fx-font-weight:bold;" text="0%" />
      </VBox>

    </HBox>
  </bottom>

</BorderPane>
